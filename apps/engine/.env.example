# ─────────────────────────────────────────────────────────────
# Active Perception 引擎配置（复制为 .env 后填写）
# 可插拔模型：两侧均支持 provider = mock | openai_compatible
#   mock              无需网络/Key，按规则产出确定性轨迹，用于跑通闭环与离线兜底
#   openai_compatible OpenAI 兼容 API（OpenRouter / vLLM / 各家），填 base_url + api_key
# ─────────────────────────────────────────────────────────────

AP_HOST=127.0.0.1
AP_PORT=8000
AP_MAX_STEPS=40

# ── "我们这一侧"（前期 Qwen3.5-VL 代理；自研基模 ready 后替换）──
AP_OURS_PROVIDER=mock
AP_OURS_MODEL_NAME=qwen/qwen3.5-vl-instruct
AP_OURS_BASE_URL=https://openrouter.ai/api/v1
AP_OURS_API_KEY=
AP_OURS_LABEL=Active Lifting (ours)

# ── baseline：Gemma 4 31B via OpenRouter ──
AP_BASELINE_PROVIDER=mock
AP_BASELINE_MODEL_NAME=google/gemma-4-31b-it
AP_BASELINE_BASE_URL=https://openrouter.ai/api/v1
AP_BASELINE_API_KEY=
AP_BASELINE_LABEL=Gemma 4 31B (baseline)

# 开发期链路排查可临时把某一侧切到最强模型（不上现场），例如：
# AP_OURS_PROVIDER=openai_compatible
# AP_OURS_MODEL_NAME=google/gemini-3-pro
