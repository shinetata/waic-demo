# ─────────────────────────────────────────────────────────────
# Active Perception 引擎配置（复制为 .env 后填写）
# 模型经 OpenAI 兼容协议接入（OpenRouter / vLLM / 各家 / 未来自研基模），
# 填 base_url + api_key + model_name。两侧（认知基模 ours / 现有做法 baseline）独立配置。
# ─────────────────────────────────────────────────────────────

AP_HOST=127.0.0.1
AP_PORT=8000
AP_MAX_STEPS=40

# ── 认知基模这一侧（前期 Qwen3.5-VL 代理；自研基模 ready 后替换）：主动感知逐步探索 ──
AP_OURS_PROVIDER=openai_compatible
AP_OURS_MODEL_NAME=qwen/qwen3.5-vl-instruct
AP_OURS_BASE_URL=https://openrouter.ai/api/v1
AP_OURS_API_KEY=
AP_OURS_LABEL=认知基模

# ── 现有做法对照：同样真实模型，但一次性读入整图、读完再想 ──
AP_BASELINE_PROVIDER=openai_compatible
AP_BASELINE_MODEL_NAME=qwen/qwen3.5-vl-instruct
AP_BASELINE_BASE_URL=https://openrouter.ai/api/v1
AP_BASELINE_API_KEY=
AP_BASELINE_LABEL=现有做法
