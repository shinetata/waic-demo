{
  "name": "@ap/protocol",
  "version": "0.1.0",
  "description": "Active Perception 轨迹协议（TS 类型 + JSON Schema），前后端共享契约",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./schema": "./schema/trajectory.schema.json"
  },
  "files": ["src", "schema", "dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
